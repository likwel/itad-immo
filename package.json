{
  "name": "itadplus",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "backend",
    "frontend",
    "liveserver"
  ],
  "scripts": {
    "dev":          "concurrently -n BACK,FRONT,LIVE -c cyan,magenta,green \"npm run dev -w backend\" \"npm run dev -w frontend\" \"npm run start -w liveserver\"",
    "dev:back":     "npm run dev      -w backend",
    "dev:front":    "npm run dev      -w frontend",
    "dev:liveserver":    "npm run start      -w liveserver",
    "build":        "npm run build    -w frontend",
    "start":        "npm run start    -w backend",
    "db:generate":  "npm run db:generate -w backend",
    "db:migrate":   "npm run db:migrate  -w backend",
    "db:seed":      "npm run db:seed     -w backend",
    "db:studio":    "npm run db:studio   -w backend",
    "db:reset":     "npm run db:reset    -w backend",
    "lint":         "concurrently \"npm run lint -w backend\" \"npm run lint -w frontend\""
  },
  "devDependencies": {
    "concurrently": "^8.2.0"
  }
}
